<Window x:Class="LifeCutdown.App.TaskbarMiniWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="任务栏窗口"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Focusable="False"
        SizeToContent="WidthAndHeight"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">
    <Border x:Name="RootBorder"
            Background="Transparent"
            Padding="4,3,6,3"
            Cursor="Hand"
            MouseLeftButtonUp="RootBorder_MouseLeftButtonUp"
            ToolTipService.ShowDuration="60000">
        <Grid SnapsToDevicePixels="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="4" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="68" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="MetricTitleTextBlock"
                           Width="68"
                           VerticalAlignment="Center"
                           FontFamily="Microsoft YaHei UI"
                           FontSize="11.5"
                           FontWeight="Bold"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock x:Name="MetricPercentageTextBlock"
                           Grid.Column="1"
                           Margin="6,0,0,0"
                           VerticalAlignment="Center"
                           FontFamily="Bahnschrift SemiCondensed"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#FF89A28E" />
            </Grid>

            <Grid x:Name="ProgressTrackGrid"
                  Grid.Row="1"
                  Margin="0,4,0,0"
                  Height="2"
                  SnapsToDevicePixels="True">
                <Rectangle Fill="#2AFFFFFF" />
                <Rectangle x:Name="ProgressFillRectangle"
                           HorizontalAlignment="Left"
                           Width="0"
                           Fill="#FF89A28E" />
            </Grid>
        </Grid>
    </Border>
</Window>