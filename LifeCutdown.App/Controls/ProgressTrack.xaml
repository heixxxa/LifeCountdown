<UserControl x:Class="LifeCutdown.App.Controls.ProgressTrack"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="RootControl"
             Height="14"
             MinHeight="14"
             SnapsToDevicePixels="True">
    <Grid x:Name="TrackRoot" Height="14" VerticalAlignment="Center">
        <Border Background="{Binding TrackBrush, ElementName=RootControl}" CornerRadius="7" />

        <Border x:Name="FillBar"
                HorizontalAlignment="Left"
                Background="{Binding FillBrush, ElementName=RootControl}"
                CornerRadius="7" />

        <Canvas IsHitTestVisible="False">
            <Border x:Name="Marker"
                    Width="4"
                    Height="{Binding MarkerHeight, ElementName=RootControl}"
                    Canvas.Top="{Binding MarkerTopOffset, ElementName=RootControl}"
                    Background="{Binding MarkerBrush, ElementName=RootControl}"
                    CornerRadius="2" />
        </Canvas>
    </Grid>
</UserControl>
