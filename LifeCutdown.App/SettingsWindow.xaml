<Window x:Class="LifeCutdown.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="420"
        Height="420"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Border Background="#F6F2EB" CornerRadius="28" Padding="24">
            <Border.Effect>
                <DropShadowEffect BlurRadius="26" ShadowDepth="8" Opacity="0.2" Color="#11000000" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,18" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <TextBlock Text="设置" FontSize="24" FontWeight="SemiBold" Foreground="#202024" />
                    <TextBlock Text="用出生日期和预期寿命，计算本周 / 本月 / 本年 / 一生的进度。"
                               Margin="0,8,0,0"
                               FontSize="12.5"
                               Foreground="#756F67"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,14">
                    <TextBlock Text="出生日期" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                    <DatePicker x:Name="BirthDatePicker" Margin="0,8,0,0" Height="36" />
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,14">
                    <TextBlock Text="预期寿命（年）" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                    <TextBox x:Name="LifeExpectancyTextBox" Margin="0,8,0,0" Height="36" VerticalContentAlignment="Center" />
                </StackPanel>

                <Grid Grid.Row="3" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="一周起点" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                        <ComboBox x:Name="WeekStartComboBox" Margin="0,8,0,0" Height="36" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="窗口位置" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                        <ComboBox x:Name="WindowAnchorComboBox" Margin="0,8,0,0" Height="36" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="4" Background="#EEE7DB" CornerRadius="20" Padding="14,12">
                    <TextBlock Text="说明：Windows 11 上很难再像旧版 DeskBand 那样直接嵌入任务栏，所以这里采用原生托盘 + 无边框悬浮面板的方式，体验接近状态栏小组件。"
                               FontSize="12.5"
                               Foreground="#756F67"
                               TextWrapping="Wrap" />
                </Border>

                <Grid Grid.Row="5" Margin="0,22,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            Content="取消"
                            Click="CancelButton_Click"
                            Margin="0,0,10,0"
                            Padding="16,9"
                            Background="#EEE7DB"
                            Foreground="#202024"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="2"
                            Content="保存"
                            Click="SaveButton_Click"
                            Padding="18,9"
                            Background="#202024"
                            Foreground="#F8F5F0"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
