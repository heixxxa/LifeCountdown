<Window x:Class="LifeCutdown.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="470"
        Height="680"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Border Background="#F6F2EB" CornerRadius="28" Padding="24">
            <Border.Effect>
                <DropShadowEffect BlurRadius="26" ShadowDepth="8" Opacity="0.2" Color="#11000000" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,18" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                            <TextBlock Text="设置" FontSize="24" FontWeight="SemiBold" Foreground="#202024" />
                            <TextBlock Text="用出生日期和预期寿命，计算本天 / 本周 / 本月 / 本年 / 一生；还可以配置一个自定义倒计时。"
                                       Margin="0,8,0,0"
                                       FontSize="12.5"
                                       Foreground="#756F67"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Background="#FCFBF7" CornerRadius="22" Padding="16" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="人生参数" FontSize="15" FontWeight="SemiBold" Foreground="#202024" />

                                <TextBlock Text="出生日期" Margin="0,14,0,0" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                                <DatePicker x:Name="BirthDatePicker" Margin="0,8,0,0" Height="36" />

                                <TextBlock Text="预期寿命（年）" Margin="0,14,0,0" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                                <TextBox x:Name="LifeExpectancyTextBox" Margin="0,8,0,0" Height="36" VerticalContentAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Border Background="#FCFBF7" CornerRadius="22" Padding="16" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="显示方式" FontSize="15" FontWeight="SemiBold" Foreground="#202024" />

                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="一周起点" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                                        <ComboBox x:Name="WeekStartComboBox" Margin="0,8,0,0" Height="36" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="窗口位置" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                                        <ComboBox x:Name="WindowAnchorComboBox" Margin="0,8,0,0" Height="36" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,14,0,0">
                                    <TextBlock Text="托盘图标显示" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                                    <ComboBox x:Name="TrayIconMetricComboBox" Margin="0,8,0,0" Height="36" />
                                    <TextBlock Text="把托盘图标渲染成所选目标的迷你进度条；悬停时会显示该目标的百分比。"
                                               Margin="0,6,0,0"
                                               FontSize="12"
                                               Foreground="#756F67"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Background="#EEE7DB" CornerRadius="16" Padding="12,10" Margin="0,14,0,0">
                                    <StackPanel>
                                        <TextBlock Text="其他托盘图标" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                                        <TextBlock Text="主界面的“托盘图标”按钮可以展开 / 收起系统隐藏图标面板。若要设置某个应用图标长期显示或隐藏，请打开 Windows 的系统托盘设置。"
                                                   Margin="0,6,0,0"
                                                   FontSize="12.5"
                                                   Foreground="#756F67"
                                                   TextWrapping="Wrap" />
                                        <Button Content="打开系统托盘设置"
                                                Click="OpenSystemTraySettingsButton_Click"
                                                Margin="0,10,0,0"
                                                Padding="14,8"
                                                HorizontalAlignment="Left"
                                                Background="#202024"
                                                Foreground="#F8F5F0"
                                                BorderThickness="0"
                                                FontWeight="SemiBold"
                                                Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Background="#FCFBF7" CornerRadius="22" Padding="16">
                            <StackPanel>
                                <TextBlock Text="自定义倒计时" FontSize="15" FontWeight="SemiBold" Foreground="#202024" />

                                <CheckBox x:Name="EnableCustomCountdownCheckBox"
                                          Content="启用自定义倒计时"
                                          Margin="0,14,0,0"
                                          FontSize="13"
                                          FontWeight="SemiBold"
                                          Foreground="#202024" />

                                <StackPanel IsEnabled="{Binding IsChecked, ElementName=EnableCustomCountdownCheckBox}">
                                    <TextBlock Text="标题" Margin="0,14,0,0" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                                    <TextBox x:Name="CustomCountdownTitleTextBox" Margin="0,8,0,0" Height="36" VerticalContentAlignment="Center" />

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="开始日期" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                                            <DatePicker x:Name="CustomCountdownStartDatePicker" Margin="0,8,0,0" Height="36" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="目标日期" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                                            <DatePicker x:Name="CustomCountdownTargetDatePicker" Margin="0,8,0,0" Height="36" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="1" Margin="0,22,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            Content="取消"
                            Click="CancelButton_Click"
                            Margin="0,0,10,0"
                            Padding="16,9"
                            Background="#EEE7DB"
                            Foreground="#202024"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="2"
                            Content="保存"
                            Click="SaveButton_Click"
                            Padding="18,9"
                            Background="#202024"
                            Foreground="#F8F5F0"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
