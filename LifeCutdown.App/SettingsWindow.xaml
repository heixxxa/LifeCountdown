<Window x:Class="LifeCutdown.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="520"
        Height="780"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Border Background="#F6F2EB" CornerRadius="28" Padding="24">
            <Border.Effect>
                <DropShadowEffect BlurRadius="26" ShadowDepth="8" Opacity="0.2" Color="#11000000" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,18" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                            <TextBlock Text="设置" FontSize="24" FontWeight="SemiBold" Foreground="#202024" />
                            <TextBlock Text="配置时间进度与多个事件进度；主界面只显示百分比、名称和进度条，悬浮时显示详细内容。"
                                       Margin="0,8,0,0"
                                       FontSize="12.5"
                                       Foreground="#756F67"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Background="#FCFBF7" CornerRadius="22" Padding="16" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="人生参数" FontSize="15" FontWeight="SemiBold" Foreground="#202024" />

                                <TextBlock Text="出生日期" Margin="0,14,0,0" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                                <DatePicker x:Name="BirthDatePicker" Margin="0,8,0,0" Height="36" />

                                <TextBlock Text="预期寿命（年）" Margin="0,14,0,0" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                                <TextBox x:Name="LifeExpectancyTextBox" Margin="0,8,0,0" Height="36" VerticalContentAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Border Background="#FCFBF7" CornerRadius="22" Padding="16" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="显示方式" FontSize="15" FontWeight="SemiBold" Foreground="#202024" />

                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="一周起点" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                                        <ComboBox x:Name="WeekStartComboBox" Margin="0,8,0,0" Height="36" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="窗口位置" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                                        <ComboBox x:Name="WindowAnchorComboBox" Margin="0,8,0,0" Height="36" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,14,0,0">
                                    <TextBlock Text="托盘图标显示" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                                    <ComboBox x:Name="TrayIconMetricComboBox" Margin="0,8,0,0" Height="36" />
                                    <TextBlock Text="如果选择“首个事件”，托盘图标会显示事件列表中的第一个事件进度。"
                                               Margin="0,6,0,0"
                                               FontSize="12"
                                               Foreground="#756F67"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Background="#EEE7DB" CornerRadius="16" Padding="12,10" Margin="0,14,0,0">
                                    <StackPanel>
                                        <TextBlock Text="系统托盘" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />
                                        <TextBlock Text="若要调整其他应用的托盘图标是否常驻显示，请打开 Windows 的系统托盘设置。"
                                                   Margin="0,6,0,0"
                                                   FontSize="12.5"
                                                   Foreground="#756F67"
                                                   TextWrapping="Wrap" />
                                        <Button Content="打开系统托盘设置"
                                                Click="OpenSystemTraySettingsButton_Click"
                                                Margin="0,10,0,0"
                                                Padding="14,8"
                                                HorizontalAlignment="Left"
                                                Background="#202024"
                                                Foreground="#F8F5F0"
                                                BorderThickness="0"
                                                FontWeight="SemiBold"
                                                Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Background="#FCFBF7" CornerRadius="22" Padding="16">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="事件进度" FontSize="15" FontWeight="SemiBold" Foreground="#202024" />
                                        <TextBlock Text="可以添加多个事件；主界面会按顺序显示它们的进度。"
                                                   Margin="0,6,0,0"
                                                   FontSize="12.5"
                                                   Foreground="#756F67"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="新增事件"
                                            Click="AddCustomEventButton_Click"
                                            Padding="14,8"
                                            Background="#202024"
                                            Foreground="#F8F5F0"
                                            BorderThickness="0"
                                            FontWeight="SemiBold"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <TextBlock Text="如果没有事件，主界面的“事件进度”部分会显示空状态提示。"
                                           Margin="0,12,0,0"
                                           FontSize="12"
                                           Foreground="#756F67"
                                           TextWrapping="Wrap" />

                                <ItemsControl x:Name="CustomEventsItemsControl" Margin="0,14,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FFFDF9" CornerRadius="18" Padding="14" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Text="事件名称" FontSize="13" FontWeight="SemiBold" Foreground="#202024" />

                                                        <Button Grid.Column="1"
                                                                Content="移除"
                                                                Click="RemoveCustomEventButton_Click"
                                                                Padding="10,4"
                                                                Background="#EEE7DB"
                                                                Foreground="#202024"
                                                                BorderThickness="0"
                                                                FontWeight="SemiBold"
                                                                Cursor="Hand">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </Grid>

                                                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,8,0,0"
                                                             Height="36"
                                                             VerticalContentAlignment="Center" />

                                                    <Grid Margin="0,12,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                            <TextBlock Text="开始日期" FontSize="12.5" FontWeight="SemiBold" Foreground="#202024" />
                                                            <DatePicker SelectedDate="{Binding StartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" Height="36" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                            <TextBlock Text="目标日期" FontSize="12.5" FontWeight="SemiBold" Foreground="#202024" />
                                                            <DatePicker SelectedDate="{Binding TargetDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" Height="36" />
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="1" Margin="0,22,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            Content="取消"
                            Click="CancelButton_Click"
                            Margin="0,0,10,0"
                            Padding="16,9"
                            Background="#EEE7DB"
                            Foreground="#202024"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="2"
                            Content="保存"
                            Click="SaveButton_Click"
                            Padding="18,9"
                            Background="#202024"
                            Foreground="#F8F5F0"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
